generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── AUTH ────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  accounts           Account[]
  transactions       Transaction[]
  budgets            Budget[]
  bodyMetrics        BodyMetric[]
  habits             Habit[]
  habitLogs          HabitLog[]
  healthLogs         HealthLog[]
  projects           Project[]
  activities         Activity[]

  @@map("users")
}

// ─── FINANCE ─────────────────────────────────────────────────────────────────

model Account {
  id        String      @id @default(cuid())
  userId    String
  name      String
  type      AccountType
  balance   Decimal     @default(0) @db.Decimal(12, 2)
  currency  String      @default("MXN")
  color     String?
  icon      String?
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("accounts")
}

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT_CARD
  CASH
  INVESTMENT
  LOAN
}

model Category {
  id       String           @id @default(cuid())
  name     String
  icon     String?
  color    String?
  type     TransactionType
  parentId String?

  parent       Category?     @relation("CategoryTree", fields: [parentId], references: [id])
  children     Category[]    @relation("CategoryTree")
  transactions Transaction[]
  budgets      Budget[]

  @@map("categories")
}

model Transaction {
  id          String          @id @default(cuid())
  userId      String
  accountId   String
  categoryId  String?
  type        TransactionType
  amount      Decimal         @db.Decimal(12, 2)
  description String?
  notes       String?
  date        DateTime
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  account  Account   @relation(fields: [accountId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id])

  @@index([userId, date])
  @@map("transactions")
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

model Budget {
  id         String   @id @default(cuid())
  userId     String
  categoryId String
  amount     Decimal  @db.Decimal(12, 2)
  period     Period
  startDate  DateTime
  endDate    DateTime?
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@map("budgets")
}

enum Period {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

// ─── BODY ────────────────────────────────────────────────────────────────────

model BodyMetric {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  weight    Decimal? @db.Decimal(5, 2)
  bodyFat   Decimal? @db.Decimal(5, 2)
  muscle    Decimal? @db.Decimal(5, 2)
  water     Decimal? @db.Decimal(5, 2)
  waist     Decimal? @db.Decimal(5, 2)
  chest     Decimal? @db.Decimal(5, 2)
  hips      Decimal? @db.Decimal(5, 2)
  arms      Decimal? @db.Decimal(5, 2)
  thighs    Decimal? @db.Decimal(5, 2)
  notes     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("body_metrics")
}

// ─── HABITS ──────────────────────────────────────────────────────────────────

model Habit {
  id          String        @id @default(cuid())
  userId      String
  name        String
  description String?
  icon        String?
  color       String?
  frequency   HabitFrequency
  targetDays  Int[]
  targetCount Int           @default(1)
  unit        String?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs HabitLog[]

  @@map("habits")
}

enum HabitFrequency {
  DAILY
  WEEKLY
  CUSTOM
}

model HabitLog {
  id        String   @id @default(cuid())
  habitId   String
  userId    String
  date      DateTime
  completed Boolean  @default(false)
  count     Int      @default(1)
  notes     String?
  createdAt DateTime @default(now())

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@index([userId, date])
  @@map("habit_logs")
}

// ─── ACTIVITIES ──────────────────────────────────────────────────────────────

model Project {
  id        String    @id @default(cuid())
  userId    String
  name      String
  color     String?
  icon      String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  activities ActivityProject[]

  @@index([userId])
  @@map("projects")
}

model Activity {
  id          String         @id @default(cuid())
  userId      String
  title       String
  description String?
  startDate   DateTime       @db.Date
  endDate     DateTime       @db.Date
  status      ActivityStatus @default(PENDING)
  priority    Priority       @default(MEDIUM)
  completedAt DateTime?
  deletedAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects ActivityProject[]

  @@index([userId, startDate])
  @@map("activities")
}

// Join table: a task can belong to many projects, a project to many tasks.
model ActivityProject {
  activityId String
  projectId  String

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([activityId, projectId])
  @@index([projectId])
  @@map("activity_projects")
}

enum ActivityStatus {
  PENDING
  IN_PROGRESS
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

// ─── HEALTH ──────────────────────────────────────────────────────────────────

model HealthLog {
  id            String   @id @default(cuid())
  userId        String
  date          DateTime
  sleepHours    Decimal? @db.Decimal(4, 2)
  sleepQuality  Int?
  energyLevel   Int?
  mood          Int?
  stressLevel   Int?
  waterLiters   Decimal? @db.Decimal(4, 2)
  caloriesIn    Int?
  caloriesOut   Int?
  stepsCount    Int?
  activeMinutes Int?
  heartRateAvg  Int?
  notes         String?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("health_logs")
}
